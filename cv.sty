% Template for CV

\usepackage{enumitem}
\usepackage{titlesec}

\usepackage[
  letterpaper,
  left=0.8in, % left=1in is too large thanks to AISTATS
  right=0.8in,
  top=1in,
  bottom=1in,
]{geometry}
\setlength\parindent{0pt}

\usepackage[
  colorlinks=true,
  linkcolor=black,
  urlcolor=black,
]{hyperref}

\usepackage[
  backend=biber,
  style=numeric,
  maxbibnames=99,
  sorting=ydnt,
  defernumbers=true,
]{biblatex}
\addbibresource{reference.bib}

% https://tex.stackexchange.com/questions/233581/ateverybibitem-clearfieldtitle-in-beamer
% Remove "in:" in bibliography
\renewbibmacro{in:}{}

\AtEveryBibitem{\clearfield{pages}}
\AtEveryBibitem{\clearfield{volume}}
\AtEveryBibitem{\clearfield{number}}
\AtEveryBibitem{\clearfield{url}}
\AtEveryBibitem{\clearfield{pdf}}
\AtEveryBibitem{\clearfield{series}}
\AtEveryBibitem{\clearfield{month}}

\AtEveryBibitem{\clearname{editor}}
\AtEveryBibitem{\clearlist{publisher}}

%%%%%%
% make name bold
% TODO: make it work with equal contributions
% https://tex.stackexchange.com/a/327046
\newcommand*{\boldname}[3]{%
  \def\lastname{#1}%
  \def\firstname{#2}%
  \def\firstinit{#3}%
}
\boldname{Wu}{Kaiwen}{K.}

\renewcommand{\mkbibnamegiven}[1]{%
  \ifboolexpr{ ( test {\ifdefequal{\firstname}{\namepartgiven}} or
    test {\ifdefequal{\firstinit}{\namepartgiven}} ) and test
  {\ifdefequal{\lastname}{\namepartfamily}} }
  {\mkbibbold{#1}}{#1}%
}

\renewcommand{\mkbibnamefamily}[1]{%
  \ifboolexpr{ ( test {\ifdefequal{\firstname}{\namepartgiven}} or
    test {\ifdefequal{\firstinit}{\namepartgiven}} ) and test
  {\ifdefequal{\lastname}{\namepartfamily}} }
  {\mkbibbold{#1}}{#1}%
}
