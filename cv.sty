\DeclareFieldFormat*{title}{#1}
\DeclareFieldFormat*{booktitle}{#1}

\usepackage{setspace}
\usepackage[dvipsnames]{xcolor}

% \titleformat{\section}{\color{BrickRed}\normalfont\large\bfseries}{}{0em}{}[{\hrule}]
\titleformat{\section}{\color{Mahogany}\normalfont\Large\bfseries}{}{0em}{}[{\hrule}]
% \titleformat{\section}{\color{RawSienna}\normalfont\large\bfseries}{}{0em}{}[{\hrule}]
\titlespacing{\section}{0pt}{8pt}{6pt}

\titleformat{\subsection}{\color{Mahogany}\normalfont\large\bfseries}{}{0em}{}[]
\titlespacing{\subsection}{0pt}{4pt}{4pt}

% tex-fmt: off
\newenvironment{compactList}{
  \begin{itemize}[leftmargin=*,noitemsep,nolistsep]
}{
  \end{itemize}
}
% tex-fmt: on

\newcommand{\spanpage}[2]{%
  #1 \hfill {#2}{\parfillskip0pt\par}%
}

% make bib fonts smaller because AISTATS' booktitle is too long..
% \renewcommand*{\bibfont}{\small}

% latex does not allow arguments in the closing section.
% https://tex.stackexchange.com/questions/17036/why-cant-the-end-code-of-an-environment-contain-an-argument
\newenvironment{education}[5][\medskip]{%
  #1%
  \spanpage{\textbf{#2}}{#3}%
  \spanpage{#4}{#5}%
}{}

\newenvironment{work}[5][\medskip]{%
  #1%
  \spanpage{\textbf{#2}}{#3}%
  \spanpage{#4}{#5}%
}{}

\newenvironment{opensource}[4][\medskip]{%
  #1%
  \textbf{#2} (\url{#3})%

  {#4}%
}{}
