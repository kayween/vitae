%%% add new line after name and title, goat answer
% https://tex.stackexchange.com/questions/351397/biblatex-add-line-breaks-after-author-and-title
\DeclareDelimFormat[bib]{nametitledelim}{\newline\bibsentence}

\usepackage{xpatch}
\makeatletter
\def\do#1{
  \ifcsdef{blx@bbx@#1}
  {\xpatchbibdriver{#1}
    {\printlist{language}%
    \newunit\newblock}
    {\printlist{language}%
    \printunit{\newline\bibsentence}}
  {}{}}
{}}
\abx@doentrytypes

% % remove quotation marks, goat
